# =============================================================
# Cross-Modal RAG System — API Configuration
# =============================================================
# Copy this file to .env and fill in your API credentials.
#   cp .env.example .env
#
# Supported providers (any OpenAI-compatible API):
#   - 通义千问 (DashScope):  https://dashscope.aliyuncs.com/compatible-mode/v1
#   - DeepSeek:             https://api.deepseek.com/v1
#   - OpenAI:               https://api.openai.com/v1
#   - SiliconFlow (免费):    https://api.siliconflow.cn/v1
# =============================================================

# LLM API configuration
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Optional: generation parameters
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7

# CLIP model (for embedding extraction)
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
CLIP_DEVICE=cuda
